{
    "name": "nodir/db-sync",
    "description": "Laravel uchun prod-local PostgreSQL sync",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Nodir",
            "email": "sizning@email.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "symfony/process": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Nodir\\DbSync\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nodir\\DbSync\\DbSyncServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
